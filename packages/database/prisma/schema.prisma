// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @unique @default(uuid())
  name          String
  contact       String  @unique
  secondContact String?
  email         String  @unique
  password      String

  createdById  String? // who created this user (admin or staff)
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]  @relation("UserCreatedBy") // users created by this admin/staff

  verifiedById  String? // who verified the agent
  verifiedBy    User?   @relation("UserVerifiedBy", fields: [verifiedById], references: [id])
  verifiedUsers User[]  @relation("UserVerifiedBy") // users verified by this admin

  isVerified Boolean  @default(false)
  role       UserRole @default(client)
  isActive   Boolean  @default(true)

  profileImageUrl  String?
  documents        UserDocument[] @relation("UserDocument")
  documentVerified UserDocument[] @relation("DocumentVerifiedBy")

  categoriesAdded     Category[]
  properties          Property[]
  districtAdded       District[]
  municipalitiesAdded Municipality[]
  wardAdded           Ward[]                  @relation("WardsAddedByAdmin")
  assignedWards       PartnerWardAssignment[] @relation("UserWards")
  assignedZones       AgentGeoZone[]          @relation("zonesAssigned")
  geoZonesCreated     GeoZone[]
  // assignedWards       Ward[]         @relation("PartnerWards")
  zonesAssigned       AgentGeoZone[]          @relation("AgentGeoZoneAssignedBy")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime?               @updatedAt
  favourites          Favourite[]
  leadsManaged               Lead[] @relation("LeadsManagedBy")
  leadsUpdated        Lead[]          @relation("LeadUpdatedBy")
  notificationEvents  NotificationEvent[]
  notificationReceive NotificationRecipient[]

  @@index([role])
  @@index([contact])
  @@index([isVerified])
}

model AgentGeoZone {
  agentId String
  zoneId  String

  agent User    @relation("zonesAssigned", fields: [agentId], references: [id])
  zone  GeoZone @relation(fields: [zoneId], references: [id])

  createdAt DateTime @default(now())

  assignedById String
  assignedBy   User   @relation("AgentGeoZoneAssignedBy", fields: [assignedById], references: [id])

  @@id([agentId, zoneId])
  @@unique([zoneId])
  @@index([zoneId])
  @@index([agentId])
}

model GeoZone {
  id       String  @id @default(uuid())
  name     String
  notes    String?
  isActive Boolean @default(true)

  // PostGIS geometry
  geom Unsupported("geometry(MultiPolygon, 4326)")

  // optional ownership / audit
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  // link to agents (many-to-many)
  agents AgentGeoZone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([geom], type: Gist)
}

model UserDocument {
  id           String       @unique @default(uuid())
  userId       String
  user         User         @relation("UserDocument", fields: [userId], references: [id])
  type         DocumentType
  url          String
  isVerified   Boolean      @default(false)
  verifiedById String?
  verifiedBy   User?        @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id])
  uploadedAt   DateTime     @default(now())
}

model PartnerWardAssignment {
  id         String   @unique @default(uuid())
  partnerId  String
  wardId     String
  partner    User     @relation("UserWards", fields: [partnerId], references: [id])
  ward       Ward     @relation("WardPartners", fields: [wardId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([wardId])
  @@unique([wardId, partnerId])
}

model Category {
  id                       String     @unique @default(uuid())
  name                     String
  imageUrl                 String
  properties               Property[]
  isLandAreaNeeded         Boolean
  isNoOfFloorsNeeded       Boolean
  isNoOfRoomsNeeded        Boolean
  isAgeOfThePropertyNeeded Boolean
  isNoOfRestRoomsNeeded    Boolean
  isFacingDirectionNeeded  Boolean
  isFloorAreaNeeded        Boolean
  isFloorLevelNeeded       Boolean
  isRoadSizeNeeded         Boolean
  addedBy                  User       @relation(fields: [addedById], references: [id])
  addedById                String
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model Property {
  id              String                               @unique @default(uuid())
  propertyCode    Int                                  @unique @default(autoincrement())
  title           String
  description     String
  price           String
  negotiable      Boolean                              @default(false)
  type            SaleType
  categoryId      String
  category        Category                             @relation(fields: [categoryId], references: [id])
  userId          String
  user            User                                 @relation(fields: [userId], references: [id])
  images          Image[]
  noOfBedRooms    String?
  noOfRestRooms   String?
  landArea        String?
  noOfFloors      String?
  propertyAge     String?
  facingDirection String?
  floorArea       String?
  roadSize        String?
  floorLevel      String?
  tole            String
  isActive        Boolean                              @default(true)
  verified        Boolean                              @default(false)
  isFeatured      Boolean                              @default(false)
  geoPoint        Unsupported("geometry(Point, 4326)")
  locationId      String
  location        Ward                                 @relation(fields: [locationId], references: [id])
  createdAt       DateTime                             @default(now())
  updatedAt       DateTime                             @updatedAt
  favourites      Favourite[]
  leads           Lead[]
  leadNotes       Json?
  features        Json?

  @@index([geoPoint], type: Gist)
  @@index([categoryId])
  @@index([type])
  @@index([userId, isActive])
  @@index([userId, isActive, verified])
}

model Favourite {
  id         String @id @default(uuid())
  userId     String
  propertyId String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model District {
  id             String         @unique @default(uuid())
  name           String         @unique
  municipalities Municipality[]
  addedById      String
  addedBy        User           @relation(fields: [addedById], references: [id])
  createdAt      DateTime       @default(now())

  @@index([name])
}

model Municipality {
  id         String   @unique @default(uuid())
  name       String
  district   District @relation(fields: [districtId], references: [id])
  districtId String
  wards      Ward[]
  addedById  String
  addedBy    User     @relation(fields: [addedById], references: [id])
  createdAt  DateTime @default(now())

  @@index([name])
}

model Ward {
  id             String                  @unique @default(uuid())
  name           String
  municipalityId String
  municipality   Municipality            @relation(fields: [municipalityId], references: [id])
  properties     Property[]
  addedById      String
  addedBy        User                    @relation("WardsAddedByAdmin", fields: [addedById], references: [id])
  partners       PartnerWardAssignment[] @relation("WardPartners")
  // partnerId      String
  // partner        User         @relation("PartnerWards", fields: [partnerId], references: [id])
  createdAt      DateTime                @default(now())
}

model Image {
  id         String   @unique @default(uuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

enum UserRole {
  admin
  partner
  client
  staff
}

enum SaleType {
  rent
  sale
}

enum DealType {
  buy
  sell
  rent
}

enum DocumentType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  LICENSE
  PAN
  PASSPORT
  OTHER
}

enum ClientType {
  BUYER
  SELLER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  FOLLOW_UP
  IN_PROGRESS
  IN_NEGOTIATION
  WON
  LOST
}

model Lead {
  id          String     @unique @default(uuid())
  leadCode    Int @unique @default(autoincrement())
  name        String?
  contact     String
  email       String?
  source      String
  clientType  ClientType
  propertyId  String?
  property    Property?   @relation(fields: [propertyId], references: [id])
  imageUrl    String?
  dealType    DealType
  coordinates String?
  managedById String?
  managedBy   User?      @relation("LeadsManagedBy",fields: [managedById], references: [id])
  notes       Json?
  followUpAt  DateTime?
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  updatedById String?
  updatedBy   User?      @relation("LeadUpdatedBy", fields: [updatedById], references: [id])
  remarks     String?
}


model NotificationEvent {
  id          String   @id @default(uuid())
  senderId    String   
  title       String   
  body        String
  link        String?  
  createdAt   DateTime @default(now())

  // Relations
  sender      User     @relation(fields: [senderId], references: [id])
  recipients  NotificationRecipient[]
}

model NotificationRecipient {
  id                  String   @id @default(uuid())
  notificationEventId String
  recipientId         String   
  isDelivered         Boolean  @default(false)
  isRead              Boolean  @default(false)
  readAt              DateTime?
  event               NotificationEvent @relation(fields: [notificationEventId], references: [id], onDelete: Cascade)
  recipient           User              @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([notificationEventId, recipientId]) // Guarantees a user doesn't get the same notification twice
}